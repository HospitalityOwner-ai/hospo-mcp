# hospo-mcp environment configuration
# Copy this to .env and fill in your real credentials
# Leave USE_MOCK_DATA=true to use realistic demo data without API keys

# ── General ───────────────────────────────────────────────────────────────────
USE_MOCK_DATA=true          # Set to false to use real APIs
LOG_LEVEL=INFO

# ── Lightspeed POS ────────────────────────────────────────────────────────────
# Get credentials at: https://cloud.lightspeedapp.com/oauth/authorize
LIGHTSPEED_CLIENT_ID=
LIGHTSPEED_CLIENT_SECRET=
LIGHTSPEED_ACCESS_TOKEN=
LIGHTSPEED_REFRESH_TOKEN=
LIGHTSPEED_ACCOUNT_ID=      # Your numeric account ID from Lightspeed
LIGHTSPEED_SANDBOX=true     # Set to false for production

# ── Xero ──────────────────────────────────────────────────────────────────────
# Get credentials at: https://developer.xero.com/app/manage
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_ACCESS_TOKEN=
XERO_REFRESH_TOKEN=
XERO_TENANT_ID=             # Your Xero organisation/tenant ID
XERO_SANDBOX=true

# ── Deputy ────────────────────────────────────────────────────────────────────
# Get API key at: https://[yoursubdomain].deputy.com/api/v1/me
DEPUTY_API_KEY=
DEPUTY_SUBDOMAIN=           # e.g. "myvenue" for myvenue.deputy.com
DEPUTY_SANDBOX=true
