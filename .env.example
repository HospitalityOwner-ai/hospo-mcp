# hospo-mcp environment configuration
# Copy this to .env and fill in your real credentials
# Leave USE_MOCK_DATA=true to use realistic demo data without API keys

# ── General ───────────────────────────────────────────────────────────────────
USE_MOCK_DATA=true          # Set to false to use real APIs
LOG_LEVEL=INFO

# ── Lightspeed O-Series (formerly Kounta) ─────────────────────────────────────
# O-Series is the dominant POS in Australian hospitality.
# Get OAuth credentials: contact developers@kounta.com
# API docs: https://apidoc.kounta.com/
LIGHTSPEED_ACCESS_TOKEN=your_oauth_token
LIGHTSPEED_REFRESH_TOKEN=                 # Optional — for auto-refresh
LIGHTSPEED_CLIENT_ID=                     # OAuth app client ID
LIGHTSPEED_CLIENT_SECRET=                 # OAuth app client secret
LIGHTSPEED_SITE_ID=your_site_id           # Your O-Series site/venue ID
LIGHTSPEED_BASE_URL=https://api.kounta.com/v1

# ── Xero ──────────────────────────────────────────────────────────────────────
# Get credentials at: https://developer.xero.com/app/manage
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_ACCESS_TOKEN=
XERO_REFRESH_TOKEN=
XERO_TENANT_ID=             # Your Xero organisation/tenant ID
XERO_SANDBOX=true

# ── Deputy ────────────────────────────────────────────────────────────────────
# Get API key at: https://[yoursubdomain].deputy.com/api/v1/me
DEPUTY_API_KEY=
DEPUTY_SUBDOMAIN=           # e.g. "myvenue" for myvenue.deputy.com
DEPUTY_SANDBOX=true
